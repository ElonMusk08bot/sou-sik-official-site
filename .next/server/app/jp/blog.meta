{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/jp/layout,_N_T_/jp/blog/layout,_N_T_/jp/blog/page,_N_T_/jp/blog"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/jp/blog/__PAGE__",
    "/jp/blog",
    "/jp",
    "/_index",
    "/_head"
  ]
}