{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/en/layout,_N_T_/en/blog/layout,_N_T_/en/blog/page,_N_T_/en/blog"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/en/blog/__PAGE__",
    "/en/blog",
    "/en",
    "/_index",
    "/_head"
  ]
}