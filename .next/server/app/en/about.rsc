7:["$","$1","c",{"children":[["$","main",null,{"className":"pt-24","children":[["$","section",null,{"className":"section","children":["$","div",null,{"className":"container-x grid gap-10 md:grid-cols-2","children":[["$","div",null,{"children":[["$","p",null,{"className":"eyebrow mb-5","children":"About Sou Sik"}],["$","h1",null,{"className":"text-4xl md:text-6xl font-semibold tracking-tight text-balance","children":"We started from product development, not marketing."}]]}],["$","div",null,{"className":"prose-sou","children":[["$","p",null,{"children":"Sou Sik is a coffee grinder brand built around precision mechanics and specialty coffee. We spent our time on product structure, grinding feel, and long-term user experience before building this website."}],["$","p",null,{"children":"We believe a brand isn't packaged into existence—it begins the moment a user turns the handle, feels the resistance change, and hears the gears click into place."}]]}]]}]}],["$","section",null,{"className":"section bg-white/[.03]","children":["$","div",null,{"className":"container-x grid gap-8 md:grid-cols-3","children":[["$","div",null,{"className":"card","children":[["$","h2",null,{"className":"mb-3 text-2xl font-semibold","children":"Mechanical"}],["$","p",null,{"className":"leading-7 text-white/60","children":"Let the mechanical structure become the experience itself, not a hidden part."}]]}],["$","div",null,{"className":"card","children":[["$","h2",null,{"className":"mb-3 text-2xl font-semibold","children":"Coffee"}],["$","p",null,{"className":"leading-7 text-white/60","children":"Serving real brewing, not just spec sheets. More stable from light roasts to daily cups."}]]}],["$","div",null,{"className":"card","children":[["$","h2",null,{"className":"mb-3 text-2xl font-semibold","children":"Ritual"}],["$","p",null,{"className":"leading-7 text-white/60","children":"Grinding isn't preparation—it's the first ritual of the coffee experience."}]]}]]}]}],["$","section",null,{"className":"section","children":["$","div",null,{"className":"container-x max-w-4xl prose-sou","children":[["$","h2",null,{"children":"What do we want to change?"}],["$","p",null,{"children":"Many hand grinders treat \"hard, exhausting, jerky\" as normal, especially with light-roast beans. Sou Sik wants to bring mechanical engineering into coffee tools—so that effort reduction, stability, and playability coexist."}],["$","h2",null,{"children":"P-1, Our First Product"}],["$","p",null,{"children":"P-1 is Sou Sik's first concrete answer. It uses a planetary gear torque system, large-format conical burrs, and low-retention design—so hand grinding isn't just a utility, but a mechanical artifact worth appreciating, disassembling, and understanding."}]]}]}],["$","section",null,{"className":"section","children":["$","div",null,{"className":"container-x","children":["$","div",null,{"className":"rounded-[2.5rem] border border-white/10 bg-white text-black p-8 md:p-14","children":[["$","p",null,{"className":"mb-3 text-xs tracking-[.28em] uppercase text-black/50","children":"Official Store"}],["$","h2",null,{"className":"max-w-3xl text-3xl md:text-5xl font-semibold tracking-tight text-balance","children":"讓每一次研磨，都成為值得期待的機械儀式。"}],["$","div",null,{"className":"mt-8 flex flex-wrap gap-3","children":[["$","a",null,{"href":"https://shop.yoursite.com","className":"rounded-full bg-black px-6 py-3 text-sm font-semibold text-white","children":"前往官方購物車"}],["$","$L2",null,{"href":"/product","className":"rounded-full border border-black/15 px-6 py-3 text-sm font-semibold","children":"了解 P-1"}]]}],["$","p",null,{"className":"mt-5 text-sm text-black/50","children":"請將連結改成你的 1Shop / SHOPLINE 商品或購物車網址。"}]]}]}]}]]}],null,["$","$Lc",null,{"children":["$","$d",null,{"name":"Next.MetadataOutlet","children":"$@e"}]}]]}]
